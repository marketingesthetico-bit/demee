rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User root document: email, plan, stripeCustomerId. Only the owner reads or writes.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Public-facing profile subdocument. Anyone reads (needed for demee.app/[handle]),
      // only the owner writes.
      match /profile/{doc=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Budget config. Public read so the /[handle]/budget form can render.
      // Only owner writes from the client; server can also write via Admin SDK.
      match /budget/{doc=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Booking config. Public read so the /[handle]/book page can render.
      match /booking/{doc=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Handle → uid index. Public read so /[handle] can resolve. Writes are
    // blocked on the client; the /api/users route mints handles atomically
    // via the Admin SDK (which bypasses these rules).
    match /handles/{handle} {
      allow read: if true;
      allow write: if false;
    }

    // Leads are created by the public budget form via the API route (Admin SDK,
    // which bypasses these rules). Only the owner reads or updates their own.
    match /leads/{leadId} {
      allow create: if false;
      allow read, update: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;
      allow delete: if false;
    }

    // Bookings: same pattern — public /book form calls the API, only
    // the owner can read or update their own bookings.
    match /bookings/{bookingId} {
      allow create: if false;
      allow read, update: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;
      allow delete: if false;
    }

    // Deny-by-default for everything else until rules are defined.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
